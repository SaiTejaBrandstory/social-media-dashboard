# Neon PostgreSQL — Dashboard → Connect → copy the *pooled* string (-pooler in host).
# Paste the full line from Neon (do not mix an old password with a new host).
# If auth fails: Roles → reset password, copy a fresh string.
# Prisma: use sslmode=require only — omit channel_binding=require if Neon adds it.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Production (Vercel): your deployed URL, e.g. https://your-app.vercel.app
# Dev: match whatever port `npm run dev` uses (default 3000; override with PORT below)
AUTH_URL=http://localhost:3000

# Optional dev server port (Next default: 3000; if busy, Next tries 3001, 3002, …)
# PORT=3002

# Google OAuth (Cloud Console → Web application)
AUTH_GOOGLE_ID=123456789-xxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxxxxxxx

# Neon: use the *pooled* connection string (hostname contains -pooler) to avoid idle disconnect errors

# OpenRouter — calendar generation, briefs, trends
OPENROUTER_API_KEY=sk-or-v1-...
